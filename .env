# Microsoft 365 (Azure AD)
M365_TENANT_ID=your-azure-tenant-id
M365_CLIENT_ID=your-azure-client-id
M365_CLIENT_SECRET=your-azure-client-secret
M365_DOMAIN=yourorg.onmicrosoft.com

# Zoom (Server-to-Server OAuth)
ZOOM_ACCOUNT_ID=your-zoom-account-id
ZOOM_CLIENT_ID=your-zoom-client-id
ZOOM_CLIENT_SECRET=your-zoom-client-secret

# ServiceNow
SERVICENOW_INSTANCE=your-instance.service-now.com
SERVICENOW_USERNAME=admin
SERVICENOW_PASSWORD=your-servicenow-password

# SAP (SCIM 2.0)
SAP_SCIM_BASE_URL=https://yourorg.accounts.ondemand.com/scim/v2
SAP_CLIENT_ID=your-sap-client-id
SAP_CLIENT_SECRET=your-sap-client-secret

# Zoho Directory (OAuth 2.0 Server-to-Server)
ZOHO_CLIENT_ID=your-zoho-client-id
ZOHO_CLIENT_SECRET=your-zoho-client-secret
ZOHO_REFRESH_TOKEN=your-zoho-refresh-token
ZOHO_ORG_ID=your-zoho-org-id
# Region-specific: https://accounts.zoho.in / .eu / .com.au / .jp
ZOHO_ACCOUNTS_URL=https://accounts.zoho.com

# Redis (optional — system works without it)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# OpenAI (optional — falls back to deterministic rules if missing)
OPENAI_API_KEY=

# AES-256-GCM Encryption Key (32 bytes hex = 64 chars)
ENCRYPTION_KEY=a1b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c1d2e3f4a5b6c7d8e9f0a1b2

# SMTP Email (leave SMTP_HOST empty to use console-log fallback in dev)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="ITSM Agent <noreply@terralogic.com>"

# Logging
LOG_LEVEL=info

# Company
COMPANY_EMAIL_DOMAIN=terralogic.com
FEATURE_PROVISIONING=true
FEATURE_NOTIFICATIONS=true
